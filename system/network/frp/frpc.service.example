[Unit]
Description=frp Client (Minecraft Server)
After=network.target

[Service]
Type=simple
User=minecraft
WorkingDirectory=/minecraft/server/frp_linux_amd64
ExecStart=/minecraft/server/frp_linux_amd64/frpc -c /minecraft/server/frp_linux_amd64/frpc.toml

Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target

server {
    listen 80;
    listen [::]:80;

    server_name wiki.website.net;

    # HTTP → HTTPS редирект
    return 301 https://wiki.website.net$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name wiki.website.net;

    # Пути к сертификатам (заменить на свои)
    ssl_certificate /etc/nginx/ssl/website.pem;
    ssl_certificate_key /etc/nginx/ssl/website.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location / {
        # Проксирование на wiki.js (локально)
        proxy_pass http://127.0.0.1:1234; # Заменить на свой

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support (нужен для wiki.js)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_buffering off;
        proxy_read_timeout 300s;
    }
}
